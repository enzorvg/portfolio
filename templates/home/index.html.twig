{# ============================================================
   PANEL slide-in projet
   ============================================================ #}
<div class="panel-mask" id="panelMask"></div>
<aside class="panel" id="projectPanel" aria-hidden="true">
    <div class="panel-head">
        <span class="panel-tag" id="panelYear"></span>
        <button class="panel-close" id="panelClose" aria-label="Fermer">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                <path d="M3 3l8 8M11 3l-8 8"/>
            </svg>
        </button>
    </div>
    <div class="panel-body">
        <h3 id="panelTitle"></h3>
        <div class="sub" id="panelSub">Projet</div>
        <div class="panel-thumb" id="panelThumb">
            <img id="panelImg" src="" alt="">
        </div>
        <p id="panelDesc"></p>
        <div class="panel-section" id="panelStackSection">
            <h4>Stack</h4>
            <div class="panel-pills" id="panelStack"></div>
        </div>
        <div id="panelGithubWrap" style="margin-top: 20px; display: none;">
            <a id="panelGithub" href="#" target="_blank" rel="noreferrer" class="github-link">
                Voir sur GitHub ↗
            </a>
        </div>
        <div style="margin-top: 28px;">
            <a id="panelDetailLink" href="#" class="btn primary">
                Voir le projet complet
                <span class="arr" aria-hidden="true">→</span>
            </a>
        </div>
    </div>
</aside>

{% endblock %}

{% block javascripts %}
<script>
(function () {
    var mask = document.getElementById('panelMask');
    var panel = document.getElementById('projectPanel');
    var closeBtn = document.getElementById('panelClose');

    function openPanel(card) {
        document.getElementById('panelYear').textContent = card.dataset.year || '';
        document.getElementById('panelTitle').textContent = card.dataset.title || '';
        document.getElementById('panelDesc').textContent = card.dataset.desc || '';

        var img = document.getElementById('panelImg');
        img.src = card.dataset.img || '';
        img.alt = card.dataset.title || '';

        var stackEl = document.getElementById('panelStack');
        stackEl.innerHTML = '';
        if (card.dataset.stack) {
            card.dataset.stack.split(', ').filter(Boolean).forEach(function (s) {
                var sp = document.createElement('span');
                sp.className = 'pill';
                sp.textContent = s;
                stackEl.appendChild(sp);
            });
        }

        var ghWrap = document.getElementById('panelGithubWrap');
        if (card.dataset.github) {
            document.getElementById('panelGithub').href = card.dataset.github;
            ghWrap.style.display = 'block';
        } else {
            ghWrap.style.display = 'none';
        }

        document.getElementById('panelDetailLink').href = card.dataset.url || '#';

        mask.classList.add('open');
        panel.classList.add('open');
        panel.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
    }

    function closePanel() {
        mask.classList.remove('open');
        panel.classList.remove('open');
        panel.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
    }

    document.querySelectorAll('.project-card[data-id]').forEach(function (card) {
        card.addEventListener('click', function () { openPanel(card); });
        card.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openPanel(card); }
        });
    });

    mask.addEventListener('click', closePanel);
    closeBtn.addEventListener('click', closePanel);
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') { closePanel(); }
    });
})();
</script>
{% endblock %}
