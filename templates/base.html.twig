<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Enzo Ravignon — Développeur Full-Stack{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Work+Sans:wght@300;400;500;600;700&display=swap">
    <link href="{{ asset('css/app.css') }}" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
</head>
<body>

    <header class="nav">
        <div class="container nav-row">
            <a href="{{ path('app_home') }}" class="brand">
                <span class="brand-mark">ER</span>
                <span>
                    <span class="brand-name">Enzo Ravignon</span>
                    <span class="brand-role">Dev Full-Stack</span>
                </span>
            </a>
            <nav class="nav-links" aria-label="Sections">
                <a href="{{ path('app_home') }}#about">À propos</a>
                <a href="{{ path('projet_index') }}">Projets</a>
                <a href="{{ path('app_home') }}#skills">Compétences</a>
                <a href="{{ path('app_home') }}#parcours">Parcours</a>
            </nav>
            <a href="{{ path('contact') }}" class="nav-cta">Me contacter</a>
        </div>
    </header>

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer>
        <div class="container foot-row">
            <span>© {{ "now"|date("Y") }} Enzo Ravignon — Conçu et codé depuis Charleville.</span>
            <span>Portfolio personnel</span>
        </div>
    </footer>

    {% block javascripts %}{% endblock %}

</body>
</html>
