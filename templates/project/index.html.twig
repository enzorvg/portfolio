{% extends 'base.html.twig' %}

{% block title %}Mes Projets — Enzo Ravignon{% endblock %}

{% block body %}

<div style="background: var(--bg-soft); padding-bottom: 1px;">
    <div class="container">
        <div class="page-hero">
            <a href="{{ path('app_home') }}" class="back-link">← Accueil</a>
            <h1>Mes Projets</h1>
            <p>Découvrez l'ensemble de mes réalisations et expérimentations.</p>
        </div>
    </div>
</div>

<div class="container" style="padding-top: clamp(40px, 5vw, 64px); padding-bottom: clamp(64px, 8vw, 120px);">
    {% if projets is empty %}
        <p style="color: var(--ink-soft); font-size: 17px;">Aucun projet disponible pour le moment.</p>
    {% else %}
        <div class="projects-grid">
            {% for projet in projets %}
                {% set logo = projet.images|filter(img => img.name and img.name|lower == 'logo' and img.image)|first %}
                {% if logo is not null and logo.image is defined %}
                    {% set ext = logo.image|split('.')|last|lower %}
                    {% set imgPath = ext in ['mp4','webm','ogg','ogv'] ? asset('images/default.png') : asset('img/' ~ logo.image) %}
                {% else %}
                    {% set imgPath = asset('images/default.png') %}
                {% endif %}
                <a href="{{ path('projet_show', {id: projet.id}) }}" style="display: contents; text-decoration: none; color: inherit;">
                    <article class="project-card" style="cursor: pointer;">
                        <div class="pc-row">
                            <span class="pc-badge">
                                <span class="num">{{ '%02d'|format(loop.index) }}</span>
                                {{ projet.createdAt|date('Y') }}
                            </span>
                            <span class="pc-arrow" aria-hidden="true">↗</span>
                        </div>
                        <h3 class="pc-title">{{ projet.name }}</h3>
                        <p class="pc-desc">{{ projet.description|slice(0, 140) }}{% if projet.description|length > 140 %}…{% endif %}</p>
                        <div class="pc-tags">
                            {% for lang in projet.language %}
                                <span class="pill">{{ lang.name }}</span>
                            {% endfor %}
                            <span class="pill alt">{{ projet.createdAt|date('d/m/Y') }}</span>
                        </div>
                    </article>
                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>

{% endblock %}
